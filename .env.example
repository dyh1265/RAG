# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- LLM Providers ---
OPENAI_API_KEY=sk-
# OLLAMA_BASE_URL=http://localhost:11434   # local Ollama; in Docker point this at your host (Linux: http://host.docker.internal:11434)
# USE_COLPALI=false          # set true + --colpali to use ColPali for page_chunks
# COLPALI_MODEL=vidore/colqwen2-v1.0   # or vidore/colSmol-500M for CPU
# HF_TOKEN=hf_...            # optional — read by huggingface_hub for faster / gated model downloads

# --- Retrieval pipeline toggles ---
# USE_HYBRID=true            # BM25 + dense fusion on text_chunks
# USE_RECURSIVE_CHUNKER=true
# USE_SEMANTIC_CHUNKER=false # alternative to recursive chunking
# USE_SECTION_PATHS=true
# USE_CONTEXT_ENRICHMENT=true
# USE_PARENT_EXPAND=true     # expand child hits to parent chunks at query time
# USE_FLASHRANK=false        # lightweight cross-encoder reranker
# USE_OCR=true               # Tesseract OCR for image-only PDF pages at ingest
# OCR_LANG=eng

# --- Vector DB ---
# QDRANT_API_KEY=          # only needed for Qdrant Cloud; leave blank for local Docker

# --- Embedding device ---
# EMBEDDING_DEVICE=cuda    # set to "cuda" if you have a GPU

# --- Optional overrides (defaults live in backend/core/config.py) ---
# OPENAI_MODEL=gpt-4o
# TEXT_EMBEDDING_MODEL=BAAI/bge-m3
# QDRANT_URL=http://localhost:6333
# REDIS_URL=redis://localhost:6379
# LOG_LEVEL=INFO

# --- API + guardrails ---
# USE_PII_REDACTION=true              # Presidio + spaCy redaction on /query
# USE_PII_REDACTION_ON_INGEST=true    # also redact at ingest time
# USE_TAXONOMY_VALIDATION=true        # block answers that violate the RDF taxonomy
# TAXONOMY_BLOCK_FORBIDDEN=false      # hard-block (true) vs warn (false) on forbidden mentions
# API_WARMUP_MODELS=true              # eager-load models on boot (slower start, faster first query)

# --- Observability ---
# OTLP_ENDPOINT=http://localhost:4317   # in Docker compose: http://jaeger:4317

# --- RAG evaluation (tests/eval/, .github/workflows/eval.yml) ---
# EVAL_TOP_K=10
# EVAL_RECALL_AT_5_THRESHOLD=0.70
# EVAL_HIT_AT_5_THRESHOLD=0.80
# EVAL_MRR_THRESHOLD=0.50
# EVAL_KEYWORD_COVERAGE_THRESHOLD=0.66
# EVAL_RETRIEVAL_LATENCY_P95_MS=60000   # retrieve-only p95 after warmup (local dev)
# EVAL_LATENCY_P95_MS=60000            # reserved for future end-to-end wall-clock checks
# RUN_RAGAS_EVAL=1           # pip install -e ".[eval]" then run Ragas faithfulness test
