# Phase 1 demo image — PDF ingest + text embedding + Qdrant search.
# Optimized for demo.py; not the full multimodal (OCR/ColPali) stack.

FROM python:3.11-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    EMBEDDING_DEVICE=cpu \
    PIP_NO_CACHE_DIR=1

RUN pip install --upgrade pip \
    && pip install \
        "pydantic>=2.0" \
        "pydantic-settings>=2.0" \
        "python-dotenv>=1.0" \
        "pymupdf>=1.24" \
        "pdfplumber>=0.11" \
        "qdrant-client>=1.12.0,<1.13.0" \
    && pip install torch torchvision --index-url https://download.pytorch.org/whl/cpu \
    && pip install "sentence-transformers>=3.0" "open_clip_torch>=2.24" "httpx>=0.27" \
        "rank-bm25>=0.2" "langchain-text-splitters>=0.3" "tiktoken>=0.7" "flashrank>=0.2" \
        "jinja2>=3.1"

COPY shared/ shared/
COPY phases/ phases/

ENTRYPOINT ["python", "phases/phase_01_multimodal_ingestion/demo.py"]
