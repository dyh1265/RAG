# Phase 1 GPU image — NGC PyTorch base + ColPali page embeddings + Qdrant search.
# Requires NVIDIA GPU + Container Toolkit on the host.
#
# Base: https://catalog.ngc.nvidia.com/orgs/nvidia/containers/pytorch
# Use 25.02+ (torch 2.7): 24.12 torch 2.6 lacks dynamo symbols required by transformers 5.x.

FROM nvcr.io/nvidia/pytorch:25.02-py3

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    EMBEDDING_DEVICE=cuda \
    USE_COLPALI=true \
    PIP_NO_CACHE_DIR=1

# PyTorch + CUDA are preinstalled — do not pip-install torch/torchvision.
# Pin HF stack to versions compatible with NGC torch and colpali-engine 0.3.16.
RUN pip install --upgrade pip \
    && pip install \
        "pydantic>=2.0" \
        "pydantic-settings>=2.0" \
        "python-dotenv>=1.0" \
        "pymupdf>=1.24" \
        "pdfplumber>=0.11" \
        "qdrant-client>=1.12.0,<1.13.0" \
        "httpx>=0.27" \
        "accelerate>=1.1.0,<2.0.0" \
        "transformers>=5.3.0,<6.0.0" \
        "peft>=0.18.0,<0.20.0" \
        "sentence-transformers>=3.4.0,<6.0.0" \
        "open_clip_torch>=2.24" \
        "colpali-engine>=0.3.16" \
        "rank-bm25>=0.2" \
        "langchain-text-splitters>=0.3" \
        "tiktoken>=0.7" \
        "flashrank>=0.2" \
        "jinja2>=3.1" \
        "rdflib>=7.0" \
        "rapidfuzz>=3.0"

COPY shared/ shared/
COPY phases/ phases/
COPY data/taxonomies/ data/taxonomies/

ENTRYPOINT ["python", "phases/phase_01_multimodal_ingestion/demo.py"]
